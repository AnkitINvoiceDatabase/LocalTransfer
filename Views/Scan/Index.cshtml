@* @{
    ViewData["Title"] = "QR Scanner";
}

<link rel="stylesheet"
      href="https://unpkg.com/html5-qrcode/html5-qrcode.css" />

<div class="container mt-4">

    <h2>QR Scanner</h2>

    <hr />

    <div id="reader" style="width:500px;"></div>

    <br />

    <button class="btn btn-primary" onclick="startScanner()">
        Open Camera
    </button>

    <button class="btn btn-danger" onclick="stopScanner()">
        Stop Camera
    </button>

    <hr />

    <h4>OR Upload QR Image</h4>

    <input type="file"
           id="qrFile"
           accept="image/*" />

    <button class="btn btn-success"
            onclick="uploadQr()">
        Upload & Scan
    </button>

    <br /><br />

    <h4>QR Result</h4>

    <textarea id="result"
              class="form-control"
              rows="4"></textarea>

    <br />

    <div id="status"
         class="alert alert-info">
        Waiting...
    </div>

</div>

<script src="https://unpkg.com/html5-qrcode"></script>

<script>

    let scanner = null;

    //------------------------------------
    // Camera Scan
    //------------------------------------

    function startScanner() {

        scanner = new Html5Qrcode("reader");

        scanner.start(
            { facingMode: "environment" },
            {
                fps: 10,
                qrbox: 250
            },
            function (decodedText) {

                document.getElementById("result").value = decodedText;

                connect(getToken(decodedText));

            }
        );
    }

    //------------------------------------
    // Stop Camera
    //------------------------------------

    function stopScanner() {

        if (scanner) {

            scanner.stop();

        }

    }

    //------------------------------------
    // Upload QR Image
    //------------------------------------

    async function uploadQr() {

        let file = document.getElementById("qrFile").files[0];

        if (!file) {

            alert("Please select QR image.");

            return;

        }

        let formData = new FormData();

        formData.append("file", file);

        const response = await fetch("/Scan/Upload", {

            method: "POST",

            body: formData

        });

        const data = await response.json();

        if (!data.success) {

            alert(data.message);

            return;

        }

        document.getElementById("result").value = data.qrText;

        connect(data.token);

    }

    //------------------------------------
    // Connect API
    //------------------------------------

    async function connect(token) {

        const response = await fetch("/api/pair/connect", {

            method: "POST",

            headers: {

                "Content-Type": "application/json"

            },

            body: JSON.stringify({

                token: token,

                deviceName: navigator.platform,

                deviceType: "Browser"

            })

        });

        const result = await response.json();

        if (result.connected) {

            document.getElementById("status").innerHTML =
                "<b style='color:green'>Connected Successfully</b>";

            // Upload Page
            // window.location="/File/Upload";

        }
        else {

            document.getElementById("status").innerHTML =
                "<b style='color:red'>Connection Failed</b>";

        }

    }

    //------------------------------------
    // Token
    //------------------------------------

    function getToken(text) {

        try {

            const url = new URL(text);

            return url.searchParams.get("token");

        }
        catch {

            return text;

        }

    }

</script> *@
