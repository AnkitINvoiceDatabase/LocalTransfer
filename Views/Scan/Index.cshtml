            font-weight: 600;
            cursor: pointer;
            background-image: linear-gradient(var(--cyan),var(--cyan));
            background-size: 0% 1px;
            background-position: 0 100%;
            background-repeat: no-repeat;
            transition: background-size .3s var(--ease);
        }

            .browse-link:hover {
                background-size: 100% 1px;
            }

        .upload-note {
            display: flex;
            align-items: center;
            gap: .6rem;
            justify-content: center;
            margin-top: 1.3rem;
            color: var(--text-faint);
            font-size: .82rem;
        }

        /* ============================================================
           FILE CARDS
           ============================================================ */
        .file-card {
            padding: 1rem 1.1rem;
            display: flex;
            align-items: center;
            gap: .9rem;
            transition: transform .3s var(--ease), border-color .3s var(--ease), box-shadow .3s var(--ease);
        }

            .file-card:hover {
                transform: translateY(-4px);
                border-color: rgba(255,255,255,.18);
                box-shadow: 0 16px 36px rgba(0,0,0,.5);
            }

        .file-icon-chip {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            color: #fff;
        }

        .file-meta {
            flex: 1;
            min-width: 0;
        }

        .file-name {
            font-weight: 600;
            font-size: .92rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .file-size {
            font-family: var(--font-mono);
            font-size: .78rem;
            color: var(--text-muted);
        }

        .remove-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 1px solid var(--surface-border);
            background: rgba(255,255,255,.03);
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: .25s var(--ease);
            cursor: pointer;
        }

            .remove-btn:hover {
                background: rgba(255,107,122,.14);
                border-color: rgba(255,107,122,.4);
                color: #FF8E9A;
                transform: scale(1.08);
            }

        /* ============================================================
           PROGRESS CARD
           ============================================================ */
        .progress-card {
            padding: 1.8rem 2rem;
        }

        .progress-top {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.1rem;
        }

        .progress-file-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--grad);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: #fff;
            flex-shrink: 0;
        }

        .progress-pct {
            font-family: var(--font-mono);
            font-size: 1.5rem;
            font-weight: 600;
            margin-left: auto;
        }

        .progress-track {
            height: 10px;
            border-radius: 999px;
            background: rgba(255,255,255,.06);
            overflow: hidden;
            position: relative;
        }

        .progress-fill {
            height: 100%;
            border-radius: 999px;
            background: var(--grad);
            width: 0%;
            transition: width .4s linear;
            position: relative;
            overflow: hidden;
        }

            .progress-fill::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(100deg, transparent, rgba(255,255,255,.45), transparent);
                width: 60px;
                animation: shimmer 1.6s linear infinite;
            }
        @@keyframes shimmer {
            0%

        {
            transform: translateX(-80px);
        }

        100% {
            transform: translateX(420px);
        }

        }

        .progress-bottom {
            display: flex;
            justify-content: space-between;
            margin-top: .8rem;
            font-size: .82rem;
            color: var(--text-muted);
        }

            .progress-bottom span b {
                color: var(--text);
                font-family: var(--font-mono);
                font-weight: 500;
            }

        .success-check {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: rgba(54,226,164,.12);
            border: 1px solid rgba(54,226,164,.4);
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--success);
            flex-shrink: 0;
            animation: pop .45s var(--ease);
        }
        @@keyframes pop {
            0%

        {
            transform: scale(.4);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }

        }

        .progress-card.is-complete .progress-file-icon {
            display: none;
        }

        .progress-card.is-complete .success-check {
            display: flex;
        }

        .progress-card.is-complete .progress-fill {
            background: linear-gradient(135deg,#36E2A4,#21B888);
        }

            .progress-card.is-complete .progress-fill::after {
                display: none;
            }

        /* ============================================================
           QR CONNECT + PHONE MOCKUP
           ============================================================ */
        .qr-card {
            padding: 2.2rem;
            text-align: center;
            perspective: 1000px;
            transition: transform .15s ease-out;
        }

        .qr-frame {
            width: 180px;
            height: 180px;
            margin: 1.4rem auto 1.2rem;
            border-radius: 18px;
            background: #fff;
            padding: 12px;
            position: relative;
            box-shadow: 0 24px 60px rgba(99,102,255,.35), 0 0 0 1px rgba(255,255,255,.06);
        }

        .qr-grid {
            width: 100%;
            height: 100%;
            display: grid;
            grid-template-columns: repeat(9,1fr);
            grid-template-rows: repeat(9,1fr);
            position: relative;
        }

        .qr-cell {
            background: transparent;
        }

            .qr-cell.on {
                background: #0a0e22;
            }

        .qr-finder {
            position: absolute;
            width: 38px;
            height: 38px;
            background: #0a0e22;
            border-radius: 4px;
        }

            .qr-finder::after {
                content: '';
                position: absolute;
                inset: 8px;
                background: #fff;
                border-radius: 2px;
            }

            .qr-finder::before {
                content: '';
                position: absolute;
                inset: 14px;
                background: #0a0e22;
                border-radius: 1px;
                z-index: 1;
            }

            .qr-finder.tl {
                top: 8px;
                left: 8px;
            }

            .qr-finder.tr {
                top: 8px;
                right: 8px;
            }

            .qr-finder.bl {
                bottom: 8px;
                left: 8px;
            }

        .qr-card h3 {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: .3rem;
        }

        .qr-card .sub-text {
            color: var(--text-muted);
            font-size: .9rem;
            max-width: 300px;
            margin: 0 auto;
        }

        .qr-tag {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            margin-top: 1.2rem;
            font-size: .78rem;
            color: var(--text-faint);
            border: 1px solid var(--surface-border);
            border-radius: 999px;
            padding: .4rem .9rem;
        }

        .phone-mockup {
            width: 150px;
            height: 300px;
            margin: 0 auto;
            border-radius: 32px;
            background: #0d1024;
            border: 3px solid rgba(255,255,255,.08);
            position: relative;
            padding: 10px;
            box-shadow: 0 30px 60px rgba(0,0,0,.55), inset 0 0 0 1px rgba(255,255,255,.04);
            animation: float-phone 4s ease-in-out infinite;
        }
        @@keyframes float-phone {
            0%,100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }

        }

        .phone-notch {
            width: 48px;
            height: 7px;
            border-radius: 6px;
            background: rgba(255,255,255,.12);
            position: absolute;
            top: 14px;
            left: 50%;
            transform: translateX(-50%);
        }

        .phone-screen {
            width: 100%;
            height: 100%;
            border-radius: 22px;
            background: linear-gradient(165deg, rgba(62,107,255,.25), rgba(155,92,255,.2) 50%, rgba(43,217,232,.18));
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            padding-top: 14px;
        }

        .phone-app-icon {
            width: 46px;
            height: 46px;
            border-radius: 13px;
            background: var(--grad);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.1rem;
            box-shadow: 0 10px 24px rgba(0,0,0,.4);
        }

        .phone-screen .ph-label {
            font-size: .62rem;
            color: rgba(255,255,255,.7);
            font-family: var(--font-mono);
        }

        /* ============================================================
           CONNECTED DEVICES PANEL
           ============================================================ */
        .devices-card {
            padding: 1.6rem;
        }

        .device-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: .85rem .9rem;
            border-radius: 14px;
            transition: background .25s var(--ease);
            cursor: default;
        }

            .device-row:hover {
                background: rgba(255,255,255,.04);
            }

            .device-row + .device-row {
                margin-top: .25rem;
            }

        .device-icon-wrap {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(255,255,255,.05);
            border: 1px solid var(--surface-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            color: var(--text);
            flex-shrink: 0;
        }

        .device-info {
            flex: 1;
            min-width: 0;
        }

        .device-name {
            font-weight: 600;
            font-size: .92rem;
        }

        .device-status {
            font-size: .78rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .status-led {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            display: inline-block;
        }

        .led-online {
            background: var(--success);
            box-shadow: 0 0 0 0 rgba(54,226,164,.6);
            animation: pulse-ring 2s infinite;
        }

        .led-idle {
            background: var(--warning);
        }

        .led-offline {
            background: #4b4f6b;
        }

        .signal-bars {
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 16px;
        }

            .signal-bars span {
                width: 4px;
                border-radius: 2px;
                background: rgba(255,255,255,.15);
            }

                .signal-bars span:nth-child(1) {
                    height: 35%;
                }

                .signal-bars span:nth-child(2) {
                    height: 55%;
                }

                .signal-bars span:nth-child(3) {
                    height: 75%;
                }

                .signal-bars span:nth-child(4) {
                    height: 100%;
                }

        .signal-4 span {
            background: var(--cyan);
        }

        .signal-3 span:nth-child(-n+3) {
            background: var(--cyan);
        }

        .signal-2 span:nth-child(-n+2) {
            background: var(--cyan);
        }

        .signal-0 span {
            background: rgba(255,255,255,.1) !important;
        }

        /* ============================================================
           RECENT TRANSFERS
           ============================================================ */
        .transfers-card {
            padding: 1.2rem 1.6rem;
        }

        .table-nimbus {
            width: 100%;
            border-collapse: collapse;
        }

            .table-nimbus thead th {
                text-transform: uppercase;
                font-size: .72rem;
                letter-spacing: .08em;
                color: var(--text-faint);
                font-weight: 600;
                padding: .9rem .8rem;
                border-bottom: 1px solid var(--line);
                text-align: left;
            }

            .table-nimbus tbody td {
                padding: .95rem .8rem;
                border-bottom: 1px solid rgba(255,255,255,.05);
                font-size: .88rem;
                vertical-align: middle;
            }

            .table-nimbus tbody tr {
                transition: background .2s var(--ease);
            }

                .table-nimbus tbody tr:hover {
                    background: rgba(255,255,255,.03);
                }

                .table-nimbus tbody tr:last-child td {
                    border-bottom: none;
                }

        .file-cell {
            display: flex;
            align-items: center;
            gap: .7rem;
        }

        .badge-status {
            font-size: .74rem;
            font-weight: 600;
            padding: .32rem .75rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
        }

        .badge-completed {
            background: rgba(54,226,164,.12);
            color: #7CF0CB;
            border: 1px solid rgba(54,226,164,.3);
        }

        .badge-progress {
            background: rgba(62,107,255,.14);
            color: #9AB1FF;
            border: 1px solid rgba(62,107,255,.32);
        }

        .badge-interrupted {
            background: rgba(255,107,122,.12);
            color: #FFA7AF;
            border: 1px solid rgba(255,107,122,.3);
        }

        .transfer-mobile-card {
            display: flex;
            align-items: center;
            gap: .8rem;
            padding: .9rem 0;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .transfer-mobile-card:last-child {
                border-bottom: none;
            }

        /* ============================================================
           FOOTER
           ============================================================ */
        .site-footer {
            position: relative;
            z-index: 1;
            padding: 2.6rem 0;
            border-top: 1px solid var(--line);
            margin-top: 2rem;
        }
    </style>
</head>
<body>

    <div class="bg-layer">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="grid-overlay"></div>
        <div class="particles" id="particles"></div>
    </div>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-nimbus py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="#top">
                <span class="brand-mark"><i class="fa-solid fa-circle-nodes"></i></span>
                <span class="brand-name">Nimbus</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" style="border-color:var(--line);">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav mx-auto mt-3 mt-lg-0 gap-1">
                    <li class="nav-item"><a class="nav-link-nimbus" href="#upload">Transfer</a></li>
                    <li class="nav-item"><a class="nav-link-nimbus" href="#connect">Devices</a></li>
                    <li class="nav-item"><a class="nav-link-nimbus" href="#transfers">History</a></li>
                </ul>
                <span class="status-chip mt-3 mt-lg-0 ms-lg-3">
                    <span class="dot-pulse"></span> Local network active
                </span>
            </div>
        </div>
    </nav>

    <main id="top">

        <!-- ===================== HERO ===================== -->
        <header class="hero">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 reveal">
                        <span class="eyebrow">Peer-to-peer · No cloud storage</span>
                        <h1>Instant <span class="text-grad">File Transfer</span></h1>
                        <p class="lead-text">Transfer files securely between your devices without cables.</p>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="#upload" class="btn-nimbus btn-primary-grad"><i class="fa-solid fa-cloud-arrow-up"></i> Upload Files</a>
                            <a href="#transfers" class="btn-nimbus btn-glass-outline"><i class="fa-regular fa-folder-open"></i> View Uploaded Files</a>
                        </div>
                        <div class="trust-row">
                            <div class="trust-item"><i class="fa-solid fa-wifi"></i> Wi-Fi</div>
                            <div class="trust-item"><i class="fa-solid fa-tower-broadcast"></i> Hotspot</div>
                            <div class="trust-item"><i class="fa-solid fa-network-wired"></i> Local Network</div>
                        </div>
                    </div>

                    <div class="col-lg-6 reveal">
                        <div class="core-stage">
                            <div class="orbit orbit-b">
                                <div class="orbit-slot slot-left"><div class="file-chip chip-img"><i class="fa-solid fa-image"></i></div></div>
                                <div class="orbit-slot slot-right"><div class="file-chip chip-vid"><i class="fa-solid fa-video"></i></div></div>
                            </div>
                            <div class="orbit orbit-a">
                                <div class="orbit-slot slot-top"><div class="file-chip chip-pdf"><i class="fa-solid fa-file-pdf"></i></div></div>
                                <div class="orbit-slot slot-bottom"><div class="file-chip chip-zip"><i class="fa-solid fa-file-zipper"></i></div></div>
                            </div>

                            <div class="connector node-conn-1" style="width:254px; transform:rotate(-42deg);">
                                <i class="fa-solid fa-chevron-right flow-arrow"></i>
                            </div>
                            <div class="connector node-conn-2" style="width:255px; transform:rotate(141deg);">
                                <i class="fa-solid fa-chevron-right flow-arrow" style="animation-delay:1.1s;"></i>
                            </div>

                            <div class="device-node node-phone glass"><i class="fa-solid fa-mobile-screen-button"></i></div>
                            <div class="device-node node-laptop glass"><i class="fa-solid fa-laptop"></i></div>

                            <div class="core-ping"></div>
                            <div class="core-ping delay"></div>
                            <div class="core-center"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- ===================== UPLOAD CARD ===================== -->
        <section class="section-pad" id="upload">
            <div class="container">
                <div class="glass upload-card reveal" style="max-width:880px; margin:0 auto;">
                    <span class="eyebrow">Send files</span>
                    <div class="dropzone mt-3" id="dropzone">
                        <div class="drop-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                        <h3>Drag &amp; Drop Files Here</h3>
                        <p class="sub-text">or <span class="browse-link" id="browseLink">browse files</span> from your device</p>
                        <input type="file" id="fileInput" multiple hidden>
                    </div>
                    <div class="upload-note">
                        <i class="fa-solid fa-shield-halved"></i>
                        Files move directly between devices over your network — nothing touches outside storage.
                    </div>
                </div>
            </div>
        </section>

        <!-- ===================== SELECTED FILES ===================== -->
        <section class="section-pad">
            <div class="container">
                <div class="section-head reveal">
                    <span class="eyebrow">Ready to send</span>
                    <h2 class="section-title">Selected Files <span class="count-badge" id="fileCount">3</span></h2>
                </div>
                <div class="row g-3" id="fileGrid">
                    <!-- file cards injected here, pre-seeded with sample state -->
                </div>
            </div>
        </section>

        <!-- ===================== UPLOAD PROGRESS ===================== -->
        <section class="section-pad">
            <div class="container">
                <div class="section-head reveal">
                    <span class="eyebrow">Uploading</span>
                    <h2 class="section-title">Transfer in Progress</h2>
                </div>
                <div class="glass progress-card reveal" id="progressCard" style="max-width:880px; margin:0 auto;">
                    <div class="progress-top">
                        <div class="progress-file-icon"><i class="fa-solid fa-file-zipper"></i></div>
                        <div class="success-check"><i class="fa-solid fa-check"></i></div>
                        <div>
                            <div class="file-name" id="progressFileName" style="font-size:1rem;">design-assets.zip</div>
                            <div class="file-size" id="progressStatus">Sending to MacBook Pro — Aman</div>
                        </div>
                        <div class="progress-pct"><span id="progressPctValue">0</span>%</div>
                    </div>
                    <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
                    <div class="progress-bottom">
                        <span>Speed: <b id="progressSpeed">0 MB/s</b></span>
                        <span>Time remaining: <b id="progressTime">—</b></span>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===================== QR CONNECT + DEVICES ===================== -->
        <section class="section-pad" id="connect">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-5 reveal">
                        <div class="glass qr-card" id="qrCard">
                            <span class="eyebrow">Quick connect</span>
                            <div class="d-flex align-items-center justify-content-center gap-4 flex-wrap">
                              @*   <div class="qr-frame">
                                     <div class="qr-grid" id="qrGrid"></div> 
                                     <div class="qr-finder tl"></div>
                                    <div class="qr-finder tr"></div>
                                    <div class="qr-finder bl"></div> 
                                </div> *@
                              @*   <div class="qr-frame">
                                    <img id="qrImage"
                                         src="/api/pair/generate"
                                         alt="QR Code"
                                         style="width:100%;height:100%;object-fit:contain;" />
                                </div> *@

                                <div class="qr-frame">
                                <img id="qrImage" alt="QR Code" style="width:100%;height:100%;object-fit:contain;display:none;" />
                                <div id="qrError" style="color:red"></div>
                            </div>


                                <div class="phone-mockup  d-sm-block">
                                    <div class="phone-notch"></div>
                                    <div class="phone-screen">
                                        <div class="phone-app-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                                        <span class="ph-label">nimbus.local</span>
                                    </div>
                                </div>
                            </div>
                            <h3 class="mt-2">Scan to Connect</h3>
                            <p class="sub-text">Open this page instantly on your mobile device.</p>
                            <span class="qr-tag"><i class="fa-solid fa-lock"></i> Works over Wi-Fi or Hotspot — no app required</span>
                        </div>
                    </div>

                    <div class="col-lg-7 reveal">
                        <div class="glass devices-card h-100">
                            <div class="d-flex align-items-baseline justify-content-between flex-wrap mb-2 px-2 pt-1">
                                <div>
                                    <span class="eyebrow">Nearby</span>
                                    <h2 class="section-title" style="font-size:1.3rem;">Connected Devices</h2>
                                </div>
                                <span class="section-sub mb-0">4 devices on this network</span>
                            </div>

                            <div class="device-row">
                                <div class="device-icon-wrap"><i class="fa-solid fa-laptop"></i></div>
                                <div class="device-info">
                                    <div class="device-name">MacBook Pro — Aman</div>
                                    <div class="device-status"><span class="status-led led-online"></span> Connected · this device</div>
                                </div>
                                <div class="signal-bars signal-4"><span></span><span></span><span></span><span></span></div>
                            </div>

                            <div class="device-row">
                                <div class="device-icon-wrap"><i class="fa-solid fa-mobile-screen-button"></i></div>
                                <div class="device-info">
                                    <div class="device-name">iPhone 15 Pro</div>
                                    <div class="device-status"><span class="status-led led-online"></span> Connected · 2 min ago</div>
                                </div>
                                <div class="signal-bars signal-3"><span></span><span></span><span></span><span></span></div>
                            </div>

                            <div class="device-row">
                                <div class="device-icon-wrap"><i class="fa-solid fa-desktop"></i></div>
                                <div class="device-info">
                                    <div class="device-name">Office Desktop</div>
                                    <div class="device-status"><span class="status-led led-idle"></span> Idle · 14 min ago</div>
                                </div>
