        }

        /* ============================================================
           UPLOAD CARD / DROPZONE
           ============================================================ */
        .upload-card {
            padding: 2.6rem;
            position: relative;
        }

        .dropzone {
            border: 2px dashed rgba(255,255,255,.16);
            border-radius: var(--r-lg);
            padding: 3.2rem 1.5rem;
