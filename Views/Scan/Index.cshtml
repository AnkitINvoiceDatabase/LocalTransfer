            mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent 75%);
        }

        .particles {
            position: absolute;
            inset: 0;
        }

        .particle {
            position: absolute;
            width: 3px;
            height: 3px;
            border-radius: 50%;
            background: #cdd3ff;
            opacity: .35;
            animation: twinkle 6s ease-in-out infinite;
        }
        @@keyframes twinkle {
            0%,100%

        {
            opacity: .12;
            transform: translateY(0);
        }

        50% {
